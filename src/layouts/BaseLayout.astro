---
import '@styles/fonts.css';
import '@styles/global.css';
import HeroCanvas from '@components/HeroCanvas.astro';
import SiteHeader from '@components/SiteHeader.astro';
import SiteFooter from '@components/SiteFooter.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  showCanvas?: boolean;
}

const {
  title = 'John Cornelius — AI & Six Sigma Lead, Night Stalker pilot, builder',
  description = 'Twenty years in Army aviation, including the 160th SOAR. Now AI & Six Sigma Lead at Tamko Building Products, scaling AI-driven process optimization across nine plants. From the ground up.',
  ogImage = '/og/default.svg',
  showCanvas = false,
} = Astro.props;

const fullTitle = title.includes('John Cornelius') ? title : `${title} — John Cornelius`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://portfolio-2026.pages.dev').toString();
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="theme-color" content="#F8F7F4" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#18140F" media="(prefers-color-scheme: dark)" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/JetBrainsMono-Variable.ttf" as="font" type="font/ttf" crossorigin />
  <link rel="manifest" href="/manifest.webmanifest" />

  <script is:inline>
    // Theme bootstrap. Light by default (highest reliable contrast across browsers).
    // Dark mode is opt-in, only applied if the user has explicitly stored 'dark'.
    (function () {
      try {
        var stored = localStorage.getItem('theme');
        if (stored === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
        else document.documentElement.setAttribute('data-theme', 'light');
      } catch (_) {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>

  <slot name="head" />
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>

  {showCanvas && <HeroCanvas />}

  <SiteHeader />

  <main id="main" tabindex="-1">
    <slot />
  </main>

  <SiteFooter />

  <noscript>
    <div class="noscript-banner">
      JavaScript is off. The site is readable — interactive features (voice agent, resume mirror, live canvas) are disabled.
    </div>
  </noscript>
</body>
</html>
