---
const items = [
  { href: '/', label: 'Home' },
  { href: '/talk', label: 'Talk' },
  { href: '/cv', label: 'CV' },
  { href: '/work', label: 'Work' },
  { href: '/contact', label: 'Contact' },
];
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="site-header">
  <div class="shell-wide site-header__inner">
    <a class="masthead" href="/" aria-label="Home" style="view-transition-name: masthead;">
      <span class="masthead__name">John Cornelius</span>
    </a>
    <nav aria-label="Primary">
      <ul class="site-nav">
        {items.map((it) => {
          const active = pathname === it.href || (it.href !== '/' && pathname.startsWith(it.href));
          return (
            <li>
              <a href={it.href} class:list={['site-nav__a', active && 'is-active']} aria-current={active ? 'page' : undefined}>
                <span class="t-mono">{String(items.indexOf(it) + 1).padStart(2, '0')}</span>
                <span>{it.label}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(8px) saturate(1.1);
    -webkit-backdrop-filter: blur(8px) saturate(1.1);
    background: color-mix(in oklch, var(--bg) 78%, transparent);
    border-bottom: 1px solid var(--rule);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding-block: var(--space-3);
    min-height: 56px;
  }
  .masthead {
    display: flex;
    flex-direction: column;
    gap: 2px;
    color: var(--fg);
    --masthead-wght: 420;
  }
  .masthead__name {
    font: var(--masthead-wght) var(--fs-md)/1 var(--font-display);
    letter-spacing: var(--tracking-md);
    font-variation-settings: 'wght' var(--masthead-wght), 'opsz' 18;
    transition: font-variation-settings 80ms linear;
  }
  .masthead__role {
    font-size: 10px;
    letter-spacing: var(--tracking-caps);
    color: var(--fg-3);
  }
  .site-nav {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: clamp(var(--space-4), 4vw, var(--space-7));
  }
  .site-nav__a {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    font-size: var(--fs-sm);
    color: var(--fg-2);
    padding-block: var(--space-2);
    position: relative;
    transition: color var(--dur-fast) var(--ease-standard);
  }
  .site-nav__a > .t-mono {
    color: var(--fg-3);
    font-size: 10px;
    letter-spacing: var(--tracking-xs);
  }
  .site-nav__a:hover,
  .site-nav__a:focus-visible { color: var(--fg); }
  .site-nav__a.is-active { color: var(--fg); }
  .site-nav__a.is-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 2px;
    background: var(--accent);
  }
  @media (max-width: 720px) {
    .masthead__role { display: none; }
    .site-nav { gap: var(--space-3); }
    .site-nav__a > .t-mono { display: none; }
    .site-nav__a { padding-inline: var(--space-1); font-size: var(--fs-xs); }
    .masthead__name { font-size: var(--fs-sm); white-space: nowrap; }
    .site-header__inner { gap: var(--space-3); padding-block: var(--space-2); min-height: 48px; }
  }
  @media (max-width: 420px) {
    .site-nav { gap: 6px; }
    .site-nav__a { padding-inline: 2px; }
  }
</style>
