---
// Voice + text agent UI mount.
// Hydrates the conversation surface client-side; the page itself stays SSR.
// Real endpoints live at /api/ask and /api/voice/* (defined separately).
---
<div class="agent" data-agent>
  <div class="agent__chrome">
    <span class="t-meta">ASK JOHN · CITED RAG · VOICE / TEXT</span>
    <span class="agent__chrome-right">
      <button type="button" class="agent__mute t-meta" data-agent-mute aria-pressed="false">Mute</button>
      <span class="t-meta agent__state" data-agent-state>idle</span>
    </span>
  </div>

  <div class="agent__log" role="log" aria-label="Conversation history" data-agent-log></div>
  <div class="visually-hidden" role="status" aria-live="polite" aria-atomic="true" data-agent-announce></div>

  <form class="agent__form" data-agent-form>
    <label for="agent-input" class="visually-hidden">Type a question</label>
    <input
      id="agent-input"
      class="agent__input"
      type="text"
      autocomplete="off"
      placeholder="Ask John about Army aviation, Tamko, manufacturing AI, or Overseer..."
      data-agent-input
    />
    <button class="agent__btn agent__btn--send" type="submit" data-agent-send>
      <span>Ask John</span>
      <kbd class="t-meta">&crarr;</kbd>
    </button>
    <button class="agent__btn agent__btn--voice" type="button" data-agent-voice aria-pressed="false" aria-label="Toggle voice mode">
      <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
        <path d="M7 1.5a2 2 0 0 1 2 2v4a2 2 0 0 1-4 0v-4a2 2 0 0 1 2-2Z M3 7v.5a4 4 0 0 0 8 0V7 M7 11.5v1" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
      </svg>
      <span>Voice</span>
    </button>
  </form>

  <p class="agent__hint t-meta">
    Answers can replay in John's cloned voice; mute keeps it text-only.
    Cite chips <span class="cite-chip">[01]</span> link to the source section.
  </p>
</div>

<script>
  import { mountAgent } from '@/lib/agent';
  const el = document.querySelector('[data-agent]') as HTMLElement | null;
  if (el) mountAgent(el);
</script>

<style>
  .visually-hidden { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

  .agent {
    position: relative;
    border: 1px solid var(--rule);
    border-radius: var(--r-3);
    background: color-mix(in oklch, var(--bg-3) 88%, transparent);
    padding: var(--space-5);
    display: grid;
    gap: var(--space-4);
    max-width: 56rem;
    margin-inline: auto;
  }
  .agent__chrome {
    display: flex; justify-content: space-between; align-items: center;
    border-bottom: 1px solid var(--rule);
    padding-bottom: var(--space-3);
  }
  .agent__chrome-right { display: inline-flex; align-items: center; gap: var(--space-3); }
  .agent__mute {
    padding: 2px 8px; border-radius: var(--r-pill); border: 1px solid var(--rule-strong);
    cursor: pointer; color: var(--fg-2); background: transparent;
    transition: color var(--dur-fast) var(--ease-standard), border-color var(--dur-fast) var(--ease-standard);
  }
  .agent__mute:hover, .agent__mute:focus-visible {
    color: var(--fg); border-color: var(--fg); outline: none;
  }
  .agent__mute[aria-pressed="true"] { color: var(--accent); border-color: var(--accent); }
  .agent__state {
    padding: 2px 8px; border-radius: var(--r-pill); border: 1px solid var(--rule-strong);
    text-transform: lowercase;
  }
  .agent__state[data-mode="listening"], .agent__state[data-mode="streaming"], .agent__state[data-mode="speaking"] { color: var(--accent); border-color: var(--accent); }

  .agent__log {
    min-height: 8rem;
    max-height: 26rem;
    overflow-y: auto;
    display: grid;
    gap: var(--space-4);
    padding: var(--space-2);
    font-size: var(--fs-base);
    line-height: var(--lh-base);
  }
  .agent__log:empty::before {
    content: "Try: 'What's your current role at Tamko?' or 'Tell me about your Army career.'";
    display: block;
    color: var(--fg-3);
    font-style: italic;
  }
  .agent__form {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: var(--space-3);
    align-items: stretch;
  }
  .agent__input {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--rule-strong);
    background: var(--bg);
    border-radius: var(--r-2);
    color: var(--fg);
    font: var(--fs-base)/1.3 var(--font-text);
    transition: border-color var(--dur-fast) var(--ease-standard);
  }
  .agent__input:focus-visible { border-color: var(--accent); outline: none; }
  .agent__btn {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--rule-strong);
    border-radius: var(--r-2);
    background: var(--bg);
    color: var(--fg);
    font: 500 var(--fs-sm)/1 var(--font-display);
    transition: background var(--dur-fast) var(--ease-standard), color var(--dur-fast) var(--ease-standard), border-color var(--dur-fast) var(--ease-standard);
  }
  .agent__btn:hover, .agent__btn:focus-visible {
    background: var(--fg); color: var(--bg); border-color: var(--fg);
  }
  .agent__btn--send { background: var(--fg); color: var(--bg); border-color: var(--fg); }
  .agent__btn--send:hover, .agent__btn--send:focus-visible { background: var(--accent); border-color: var(--accent); color: var(--accent-fg); }
  .agent__btn--voice[aria-pressed="true"] { background: var(--accent); color: var(--accent-fg); border-color: var(--accent); }
  .agent__btn kbd { background: transparent; border: 0; }

  .agent__hint { color: var(--fg-3); }
  .cite-chip {
    display: inline-block; font: 500 0.75rem/1.2 var(--font-mono);
    padding: 0 6px; margin: 0 2px;
    border: 1px solid var(--accent);
    border-radius: var(--r-pill);
    color: var(--accent);
  }

  @media (max-width: 540px) {
    .agent__form { grid-template-columns: 1fr; }
    .agent__btn { justify-content: center; }
  }
</style>
