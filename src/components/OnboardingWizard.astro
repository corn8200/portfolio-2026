---
// Onboarding wizard — styled as a personal note / handshake rather than a form.
// Three steps: who is this, what's their context, what do they want to ask.
// Animations + signature treatment make it feel like opening a letter.
---
<div
  class="wiz"
  data-onboarding
  data-onboarding-state="hidden"
  role="dialog"
  aria-modal="false"
  aria-labelledby="wiz-title"
  hidden
>
  <div class="wiz__backdrop" data-onboarding-backdrop aria-hidden="true"></div>

  <section class="wiz__sheet" data-onboarding-sheet>
    <header class="wiz__head">
      <span class="wiz__from t-mono" aria-hidden="true">
        <span class="wiz__live"></span>
        FROM JOHN
      </span>
      <span class="wiz__dots" aria-hidden="true">
        <span class="wiz__dot" data-onboarding-dot="1"></span>
        <span class="wiz__dot" data-onboarding-dot="2"></span>
        <span class="wiz__dot" data-onboarding-dot="3"></span>
      </span>
      <button
        type="button"
        class="wiz__close t-mono"
        data-onboarding-close
        aria-label="Skip and open the chat"
      >Skip</button>
    </header>

    <div class="wiz__steps">
      <!-- Step 1 -->
      <article
        class="wiz__step"
        data-onboarding-step="1"
        data-active="true"
        aria-hidden="false"
      >
        <p class="wiz__kicker t-mono">First, before we talk —</p>
        <h2 class="wiz__title" id="wiz-title">
          who am I<br />speaking with?
        </h2>
        <p class="wiz__sub">First name is fine. Skip if you'd rather stay anonymous.</p>
        <label class="visually-hidden" for="wiz-name">First name</label>
        <input
          id="wiz-name"
          class="wiz__field"
          type="text"
          autocomplete="given-name"
          maxlength="60"
          placeholder="e.g. Sam"
          data-onboarding-field="name"
          enterkeyhint="next"
        />
        <p class="t-meta wiz__keyhint">
          <kbd>Enter</kbd> to continue
        </p>
        <div class="wiz__nav">
          <button type="button" class="wiz__btn wiz__btn--ghost" data-onboarding-skip>Stay anonymous</button>
          <button type="button" class="wiz__btn wiz__btn--primary" data-onboarding-next>Continue &rarr;</button>
        </div>
      </article>

      <!-- Step 2 -->
      <article
        class="wiz__step"
        data-onboarding-step="2"
        data-active="false"
        aria-hidden="true"
      >
        <p class="wiz__kicker t-mono">And —</p>
        <h2 class="wiz__title">
          anything I<br />should know?
        </h2>
        <p class="wiz__sub">
          Company, role, what you're working on, what brought you here. The more
          you share, the more I can connect my answers to what matters to you.
        </p>
        <label class="visually-hidden" for="wiz-org">A little about you</label>
        <textarea
          id="wiz-org"
          class="wiz__field wiz__textarea"
          rows="3"
          maxlength="600"
          placeholder="e.g. CTO at a 30-person manufacturer, exploring AI for ops"
          data-onboarding-field="org"
        ></textarea>
        <p class="t-meta wiz__keyhint">
          <kbd>Enter</kbd> to continue · <kbd>Shift + Enter</kbd> for a new line
        </p>
        <div class="wiz__nav">
          <button type="button" class="wiz__btn wiz__btn--ghost" data-onboarding-skip>Skip</button>
          <button type="button" class="wiz__btn wiz__btn--primary" data-onboarding-next>Continue &rarr;</button>
        </div>
      </article>

      <!-- Step 3 -->
      <article
        class="wiz__step"
        data-onboarding-step="3"
        data-active="false"
        aria-hidden="true"
      >
        <p class="wiz__kicker t-mono">Now — your move.</p>
        <h2 class="wiz__title">
          what do you<br />want to ask?
        </h2>
        <p class="wiz__sub">Pick a starter or write your own. I'll answer in my own voice.</p>

        <ul class="wiz__prompts" role="list">
          <li>
            <button type="button" class="wiz__prompt" data-onboarding-prompt="What did you do in the Army?">
              <span class="wiz__prompt-q t-mono">Q.1</span>
              <span class="wiz__prompt-text">What did you do in the Army?</span>
            </button>
          </li>
          <li>
            <button type="button" class="wiz__prompt" data-onboarding-prompt="What's your current role at Tamko?">
              <span class="wiz__prompt-q t-mono">Q.2</span>
              <span class="wiz__prompt-text">What's your current role at Tamko?</span>
            </button>
          </li>
          <li>
            <button type="button" class="wiz__prompt" data-onboarding-prompt="What are you looking to do next?">
              <span class="wiz__prompt-q t-mono">Q.3</span>
              <span class="wiz__prompt-text">What are you looking to do next?</span>
            </button>
          </li>
          <li>
            <button type="button" class="wiz__prompt" data-onboarding-prompt="How do you approach AI in manufacturing?">
              <span class="wiz__prompt-q t-mono">Q.4</span>
              <span class="wiz__prompt-text">How do you approach AI in manufacturing?</span>
            </button>
          </li>
          <li>
            <button type="button" class="wiz__prompt" data-onboarding-prompt="Why did you leave aviation?">
              <span class="wiz__prompt-q t-mono">Q.5</span>
              <span class="wiz__prompt-text">Why did you leave aviation?</span>
            </button>
          </li>
        </ul>

        <label class="visually-hidden" for="wiz-question">Your question</label>
        <input
          id="wiz-question"
          class="wiz__field"
          type="text"
          autocomplete="off"
          placeholder="Or type your own..."
          data-onboarding-field="question"
          enterkeyhint="send"
        />
        <p class="t-meta wiz__keyhint">
          <kbd>Enter</kbd> to ask · pick a starter to jump straight in
        </p>

        <div class="wiz__nav">
          <button type="button" class="wiz__btn wiz__btn--ghost" data-onboarding-skip>Just open the chat</button>
          <button type="button" class="wiz__btn wiz__btn--primary" data-onboarding-finish>Ask John &rarr;</button>
        </div>
      </article>
    </div>

    <footer class="wiz__foot">
      <span class="wiz__sig" aria-hidden="true">— John</span>
      <span class="t-meta wiz__priv">private to this browser · skippable</span>
    </footer>
  </section>
</div>

<style>
  .visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  .wiz[hidden] { display: none; }

  .wiz {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: center;
    padding: clamp(var(--space-3), 4vw, var(--space-7));
    overflow: hidden;
  }

  .wiz__backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in oklch, var(--fg) 38%, transparent);
    backdrop-filter: blur(8px) saturate(1.1);
    -webkit-backdrop-filter: blur(8px) saturate(1.1);
  }

  .wiz__sheet {
    position: relative;
    width: min(44rem, 100%);
    max-height: min(92vh, 46rem);
    overflow-y: auto;
    background: var(--bg-3);
    color: var(--fg);
    border: 1px solid var(--rule);
    border-radius: var(--r-3);
    box-shadow: var(--shadow-lg);
    padding: clamp(var(--space-5), 5vw, var(--space-8));
    display: grid;
    gap: var(--space-5);
  }

  /* Accent corner mark — small but adds craft */
  .wiz__sheet::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: clamp(2.5rem, 6vw, 4rem);
    height: 2px;
    background: var(--accent);
    border-top-left-radius: var(--r-3);
  }

  .wiz__head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-4);
  }
  .wiz__from {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--fg-3);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
  }
  .wiz__live {
    display: inline-block;
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 color-mix(in oklch, var(--accent) 60%, transparent);
    animation: wiz-pulse 2.2s ease-out infinite;
  }
  @keyframes wiz-pulse {
    0%   { box-shadow: 0 0 0 0 color-mix(in oklch, var(--accent) 55%, transparent); }
    70%  { box-shadow: 0 0 0 9px color-mix(in oklch, var(--accent) 0%, transparent); }
    100% { box-shadow: 0 0 0 0 color-mix(in oklch, var(--accent) 0%, transparent); }
  }

  .wiz__dots {
    justify-self: center;
    display: inline-flex;
    gap: 8px;
  }
  .wiz__dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--rule-strong);
    transition: background var(--dur-base) var(--ease-emphasized), transform var(--dur-base) var(--ease-emphasized);
  }
  .wiz__dot[data-current="true"] {
    background: var(--accent);
    transform: scale(1.25);
  }
  .wiz__dot[data-done="true"] {
    background: var(--fg-2);
  }

  .wiz__close {
    background: transparent;
    border: 0;
    color: var(--fg-3);
    cursor: pointer;
    padding: 4px 10px;
    border-radius: var(--r-pill);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    transition: color var(--dur-fast) var(--ease-standard);
  }
  .wiz__close:hover, .wiz__close:focus-visible {
    color: var(--fg);
    outline: none;
  }

  .wiz__steps {
    position: relative;
    display: grid;
    grid-template-areas: "step";
    min-height: 17rem;
  }

  .wiz__step {
    grid-area: step;
    display: grid;
    gap: var(--space-4);
    align-content: start;
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition:
      opacity var(--dur-base) var(--ease-emphasized),
      transform var(--dur-base) var(--ease-emphasized);
  }
  .wiz__step[data-active="true"] {
    opacity: 1;
    pointer-events: auto;
    transform: none;
    animation: wiz-in var(--dur-slow) var(--ease-emphasized);
  }
  .wiz__step[data-leaving="true"] {
    animation: wiz-out var(--dur-base) var(--ease-exit);
  }
  @keyframes wiz-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes wiz-out {
    from { opacity: 1; transform: translateY(0); }
    to   { opacity: 0; transform: translateY(-8px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .wiz__step,
    .wiz__step[data-active="true"],
    .wiz__step[data-leaving="true"] {
      animation: none !important;
      transition: opacity var(--dur-fast) linear !important;
      transform: none !important;
    }
    .wiz__live { animation: none !important; }
  }

  .wiz__kicker {
    margin: 0;
    color: var(--fg-3);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
  }

  .wiz__title {
    margin: 0;
    font: 460 clamp(1.85rem, 4.2vw, 2.5rem)/1.05 var(--font-display);
    letter-spacing: -0.022em;
    color: var(--fg);
  }

  .wiz__sub {
    margin: 0;
    color: var(--fg-2);
    font: var(--fs-base)/var(--lh-md) var(--font-text);
    letter-spacing: 0;
    text-transform: none;
    max-width: 38ch;
  }

  .wiz__field {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--rule-strong);
    background: var(--bg);
    border-radius: var(--r-2);
    color: var(--fg);
    font: var(--fs-md)/1.3 var(--font-text);
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      box-shadow var(--dur-fast) var(--ease-standard);
    width: 100%;
  }
  .wiz__field:focus-visible {
    border-color: var(--accent);
    outline: none;
    box-shadow: 0 0 0 3px color-mix(in oklch, var(--accent) 22%, transparent);
  }
  .wiz__textarea {
    resize: vertical;
    min-height: 5rem;
    font-family: var(--font-text);
  }

  .wiz__keyhint {
    margin: 0;
    color: var(--fg-3);
    font-size: var(--fs-xs);
  }
  .wiz__keyhint kbd {
    background: var(--bg);
    border: 1px solid var(--rule);
    border-radius: var(--r-1);
    padding: 1px 6px;
    margin: 0 2px;
    font: 500 var(--fs-xs)/1.2 var(--font-mono);
    color: var(--fg-2);
  }

  .wiz__prompts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-2);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding-block: var(--space-3);
  }
  .wiz__prompts li { display: contents; }
  .wiz__prompt {
    display: grid;
    grid-template-columns: 2.75rem 1fr;
    align-items: baseline;
    gap: var(--space-3);
    width: 100%;
    padding: var(--space-3) var(--space-3);
    border: 0;
    border-radius: var(--r-2);
    background: transparent;
    color: var(--fg);
    text-align: left;
    cursor: pointer;
    transition: background var(--dur-fast) var(--ease-standard);
    font: 500 var(--fs-md)/1.35 var(--font-text);
  }
  .wiz__prompt:hover,
  .wiz__prompt:focus-visible {
    background: color-mix(in oklch, var(--accent) 8%, transparent);
    outline: none;
  }
  .wiz__prompt:hover .wiz__prompt-q,
  .wiz__prompt:focus-visible .wiz__prompt-q {
    color: var(--accent);
  }
  .wiz__prompt-q {
    color: var(--fg-3);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    transition: color var(--dur-fast) var(--ease-standard);
  }
  .wiz__prompt-text { color: inherit; }

  .wiz__nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  .wiz__btn {
    padding: var(--space-3) var(--space-5);
    border-radius: var(--r-2);
    border: 1px solid var(--rule-strong);
    background: var(--bg);
    color: var(--fg);
    font: 500 var(--fs-sm)/1 var(--font-display);
    letter-spacing: 0;
    cursor: pointer;
    transition:
      background var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .wiz__btn--ghost {
    background: transparent;
    border-color: var(--rule);
    color: var(--fg-3);
  }
  .wiz__btn--ghost:hover, .wiz__btn--ghost:focus-visible {
    color: var(--fg);
    border-color: var(--fg);
    outline: none;
  }
  .wiz__btn--primary {
    background: var(--fg);
    color: var(--bg);
    border-color: var(--fg);
  }
  .wiz__btn--primary:hover, .wiz__btn--primary:focus-visible {
    background: var(--accent);
    color: var(--accent-fg);
    border-color: var(--accent);
    outline: none;
  }

  .wiz__foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-top: 1px solid var(--rule);
    padding-top: var(--space-4);
    gap: var(--space-4);
  }
  .wiz__sig {
    font: 460 var(--fs-lg)/1 var(--font-display);
    letter-spacing: -0.012em;
    font-style: italic;
    color: var(--fg);
  }
  .wiz__priv {
    color: var(--fg-3);
    font-size: var(--fs-xs);
  }

  /* Mount-driven visibility. */
  .wiz[data-onboarding-state="hidden"] { display: none; }
  .wiz[data-onboarding-state="visible"] { display: grid; }
  .wiz[data-onboarding-state="visible"] .wiz__sheet {
    animation: wiz-rise var(--dur-slow) var(--ease-emphasized) both;
  }
  .wiz[data-onboarding-state="closing"] {
    display: grid;
    opacity: 0;
    transition: opacity var(--dur-base) var(--ease-exit);
  }
  @keyframes wiz-rise {
    from { opacity: 0; transform: translateY(18px) scale(0.985); }
    to   { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .wiz[data-onboarding-state="visible"] .wiz__sheet { animation: none !important; }
  }

  @media (max-width: 540px) {
    .wiz { padding: var(--space-2); }
    .wiz__sheet { padding: var(--space-5); }
    .wiz__head { grid-template-columns: 1fr auto; }
    .wiz__dots { display: none; }
    .wiz__nav { flex-direction: column-reverse; align-items: stretch; }
    .wiz__btn { width: 100%; text-align: center; }
    .wiz__prompt { grid-template-columns: 2.25rem 1fr; }
  }
</style>
