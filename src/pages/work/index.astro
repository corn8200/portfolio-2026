---
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectList from '@components/ProjectList.astro';
import { getAllProjects } from '@lib/content';

const projects = getAllProjects();
---
<BaseLayout
  title="Work — John Cornelius"
  description="Eight systems in production. Brain. Gateway. Memory. Queue. MCP. Each one earns its place."
>
  <section class="shell-wide page-head">
    <p class="h-eyebrow">02 / Career</p>
    <h1 class="h-display">Career</h1>
    <p class="t-lead">
      Twenty years in Army aviation, including the 160th SOAR. Three promotions in three
      and a half years at Tamko, from one plant subsidiary to corporate AI and Six Sigma Lead.
      Embry-Riddle for both degrees. And the side projects that prove I still build, not just lead.
    </p>
  </section>

  <section class="shell-wide section">
    <ProjectList projects={projects} />
  </section>
</BaseLayout>

<style>
  .page-head { padding-block: var(--space-9) var(--space-7); display: grid; gap: var(--space-4); max-width: 60rem; }
  .section { padding-block: var(--space-4) var(--space-10); }
</style>
