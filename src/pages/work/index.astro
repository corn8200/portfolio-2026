---
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectList from '@components/ProjectList.astro';
import { getAllProjects } from '@lib/content';

const projects = getAllProjects().filter((p) => p.frontmatter.slug !== 'education');
---
<BaseLayout
  title="Work — John Cornelius"
  description="Manufacturing AI, operations leadership, Army aviation, and the operator systems John Cornelius has built."
>
  <section class="shell-wide page-head">
    <p class="h-eyebrow">02 / Work</p>
    <h1 class="h-display">Work that proves the CV.</h1>
    <p class="t-lead">
      Promoted twice at Tamko in roughly three years, from plant operations into corporate AI &amp; Six Sigma.
      Twenty years of U.S. Army operations before that. The projects below show the same pattern:
      standardize the work, instrument the system, then make the new behavior durable.
    </p>
    <dl class="credential-strip" aria-label="Education">
      <div>
        <dt>MS</dt>
        <dd>Unmanned Systems, Embry-Riddle</dd>
      </div>
      <div>
        <dt>BS</dt>
        <dd>Aeronautics, Embry-Riddle</dd>
      </div>
    </dl>
  </section>

  <section class="shell-wide section">
    <ProjectList projects={projects} />
  </section>
</BaseLayout>

<style>
  .page-head { padding-block: var(--space-9) var(--space-7); display: grid; gap: var(--space-4); max-width: 60rem; }
  .section { padding-block: var(--space-4) var(--space-10); }
  .credential-strip {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--rule);
  }
  .credential-strip div {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
  }
  .credential-strip dt {
    font: 650 var(--fs-xs)/1 var(--font-mono);
    color: var(--accent);
    letter-spacing: var(--tracking-caps);
  }
  .credential-strip dd {
    margin: 0;
    color: var(--fg-2);
    font-size: var(--fs-sm);
  }
</style>
