---
import BaseLayout from '@layouts/BaseLayout.astro';
import VoiceAgent from '@components/VoiceAgent.astro';
import ProjectList from '@components/ProjectList.astro';
import ResumeMirror from '@components/ResumeMirror.astro';
import { getAllProjects } from '@lib/content';

const projects = getAllProjects();
const projectCount = projects.length;
const buildId = new Date().toISOString().slice(0, 10).replace(/-/g, '.');
---
<BaseLayout title="John Cornelius — AI & Six Sigma Lead. Night Stalker pilot. Builder.">
  <section class="hero shell-wide" aria-labelledby="hero-name">
    <div class="hero__inner">
      <p class="editorial-mark">John Cornelius &middot; Harpers Ferry, WV</p>
      <div class="hero__chrome t-meta">
        <span>BUILD {buildId}</span>
        <span><span class="dot-live" aria-hidden="true"></span> AVAILABLE</span>
      </div>

      <h1 id="hero-name" class="hero__h1">
        <span class="hero__line">Twenty years airborne.</span>
        <span class="hero__line"><span class="hero__accent">Now bringing precision to manufacturing AI.</span></span>
      </h1>

      <p class="hero__lede t-lede">
        Paratrooper. Sniper. Night Stalker pilot. Standardization Instructor.
        Today: AI and Six Sigma Lead at Tamko Building Products,
        scaling AI-driven process optimization across nine plants.
        Small-town West Virginia kid who decided to do something about 9/11 — and never stopped.
      </p>

      <dl class="hero__meta meta-row">
        <dt>role</dt><dd>AI &amp; Six Sigma Lead · Tamko Corporate</dd>
        <dt>service</dt><dd>U.S. Army · 20 years · 160th SOAR · 14 countries</dd>
        <dt>education</dt><dd>MS Unmanned Systems · BS Aeronautics · Embry-Riddle</dd>
        <dt>based</dt><dd>Harpers Ferry, West Virginia · US-eligible</dd>
        <dt>signal</dt><dd><span class="hero__accent">From the ground up.</span> That's how I've built everything.</dd>
      </dl>

      <div class="hero__cta">
        <a class="btn btn--primary" href="#talk">
          <span>Talk to John (in his voice)</span>
          <span class="t-meta">cloned · cited · sub-1s</span>
        </a>
        <a class="btn btn--ghost" href="/cv">
          <span>Read the CV</span>
          <span class="t-meta">+ download .md / pdf</span>
        </a>
        <a class="btn btn--ghost" href="/work">
          <span>See the career</span>
          <span class="t-meta">{projectCount} dossiers</span>
        </a>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <section class="shell-wide section section--work" aria-labelledby="sect-work">
    <header class="section__head">
      <p class="h-eyebrow">02 / Career</p>
      <h2 id="sect-work" class="h-1">Two careers, one operating system.</h2>
      <p class="t-body">
        Two decades in Army aviation taught me that the smallest variable can be the decisive one,
        and the only way to find it is to keep looking. That instinct is what I bring to
        manufacturing operations now — and what I'm scaling across the Tamko enterprise.
        Click any row for the full dossier.
      </p>
    </header>
    <ProjectList projects={projects} />
  </section>

  <hr class="rule" />

  <section id="talk" class="shell section section--talk" aria-labelledby="sect-talk">
    <header class="section__head">
      <p class="h-eyebrow">03 / Conversation</p>
      <h2 id="sect-talk" class="h-1">Talk to me.</h2>
      <p class="t-body">
        Real-time voice or text. The voice you hear is mine — cloned via ElevenLabs from
        two voice memos. Ask anything about my background, career, or
        operating philosophy; the model is grounded in this CV and cites the
        section it pulled from. Text mode is the always-on accessibility fallback.
      </p>
    </header>
    <VoiceAgent />
  </section>

  <hr class="rule" />

  <section class="shell section section--mirror" aria-labelledby="sect-mirror">
    <header class="section__head">
      <p class="h-eyebrow">04 / Role-fit pitch</p>
      <h2 id="sect-mirror" class="h-1">Hiring? Paste the role. Get my honest fit.</h2>
      <p class="t-body">
        Paste a job posting, role description, or quick brief about your team's problem —
        get a streamed Markdown pitch on whether and how I fit the role, citing specific
        lines from both my CV and your description. Honest, not flattering. Names the gaps
        and the genuine overlap. Rate-limited per IP. No data stored beyond a 24h hash cache.
      </p>
    </header>
    <div class="mirror-mount">
      <ResumeMirror />
      <noscript>
        <p class="t-small" style="text-align: center; margin-top: var(--space-4); color: var(--fg-3);">
          Resume mirror requires JavaScript. Email <a href="mailto:corn82@icloud.com">corn82@icloud.com</a> for a direct pitch.
        </p>
      </noscript>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(var(--space-7), 12vh, var(--space-10)) var(--space-9);
  }
  .hero__inner {
    display: grid;
    gap: var(--space-6);
    max-width: 56rem;
  }
  .hero__chrome {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
    color: var(--fg-3);
  }
  .hero__chrome > span:first-child { color: var(--fg-2); }
  .hero__h1 {
    font: 480 var(--fs-4xl)/var(--lh-4xl) var(--font-display);
    letter-spacing: var(--tracking-4xl);
    color: var(--fg);
    margin: 0;
  }
  .hero__line { display: block; }
  .hero__accent { color: var(--accent); }
  .hero__lede {
    color: var(--fg);
    font-size: var(--fs-md);
    max-width: 48ch;
  }
  .hero__meta {
    grid-template-columns: 6rem 1fr;
    max-width: 48rem;
    padding: var(--space-4) 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .hero__cta {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-2);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
    border: 1px solid var(--rule-strong);
    border-radius: var(--r-3);
    font: 500 var(--fs-sm)/1 var(--font-display);
    color: var(--fg);
    background: var(--bg-3);
    transition: background var(--dur-fast) var(--ease-standard), color var(--dur-fast) var(--ease-standard), border-color var(--dur-fast) var(--ease-standard);
  }
  .btn .t-meta { color: var(--fg-3); }
  .btn:hover, .btn:focus-visible {
    background: var(--bg);
    border-color: var(--fg);
  }
  .btn--primary {
    background: var(--fg);
    color: var(--bg);
    border-color: var(--fg);
  }
  .btn--primary .t-meta { color: color-mix(in oklch, var(--bg) 70%, var(--fg)); }
  .btn--primary:hover, .btn--primary:focus-visible {
    background: var(--accent);
    color: var(--accent-fg);
    border-color: var(--accent);
  }
  .btn--ghost { background: transparent; }

  .section { padding-block: var(--space-9); }
  .section__head { display: grid; gap: var(--space-3); max-width: 56rem; margin-bottom: var(--space-7); }

  @media (max-width: 720px) {
    .hero__h1 { font-size: clamp(2.5rem, 11vw, 4rem); }
    .hero__meta { grid-template-columns: 5rem 1fr; }
  }
</style>
