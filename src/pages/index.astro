---
import BaseLayout from '@layouts/BaseLayout.astro';
import VoiceAgent from '@components/VoiceAgent.astro';
---
<BaseLayout
  title="John Cornelius"
  description="John Cornelius builds operating systems for industrial AI, manufacturing improvement, and human-in-the-loop agent work."
>
  <section class="landing shell">
    <header class="landing__head">
      <p class="editorial-mark t-mono">Harpers Ferry, WV &middot; US-eligible</p>
      <h1 class="landing__name">John Cornelius</h1>
      <p class="landing__line">
        Industrial AI operator. Army aviation veteran.
      </p>
    </header>

    <VoiceAgent />

    <dl class="proof-strip" aria-label="Career proof points">
      <div>
        <dt class="t-mono">9 plants</dt>
        <dd>operational AI scaled</dd>
      </div>
      <div>
        <dt class="t-mono">20 yr</dt>
        <dd>Army aviation</dd>
      </div>
      <div>
        <dt class="t-mono">2 promotions</dt>
        <dd>3 yr</dd>
      </div>
    </dl>

    <footer class="landing__foot t-meta">
      <span>corn82@icloud.com</span>
      <span aria-hidden="true">&middot;</span>
      <a href="https://github.com/corn8200" rel="noopener">github.com/corn8200</a>
    </footer>
  </section>
</BaseLayout>

<style>
  .landing {
    min-height: 82svh;
    padding-block: var(--space-8) var(--space-10);
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: var(--space-7);
    max-width: 64rem;
  }

  .landing__head { display: grid; gap: var(--space-4); }
  .landing__name {
    font: 460 var(--fs-3xl)/1 var(--font-display);
    letter-spacing: 0;
    color: var(--fg);
    margin: 0;
  }
  .landing__line {
    font: 480 var(--fs-4xl)/var(--lh-4xl) var(--font-display);
    letter-spacing: 0;
    color: var(--fg);
    max-width: 16ch;
    margin: 0;
  }

  .proof-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin: 0;
  }
  .proof-strip div {
    display: grid;
    gap: var(--space-1);
    padding: var(--space-4) var(--space-5);
  }
  .proof-strip div + div {
    border-left: 1px solid var(--rule);
  }
  .proof-strip dt {
    color: var(--fg);
    font-size: var(--fs-sm);
    letter-spacing: var(--tracking-xs);
  }
  .proof-strip dd {
    color: var(--fg-3);
    font-size: var(--fs-xs);
    margin: 0;
  }

  :global(.landing .agent) {
    max-width: none;
    margin-inline: 0;
  }

  .landing__foot {
    display: flex;
    gap: var(--space-3);
    color: var(--fg-3);
    flex-wrap: wrap;
    align-items: center;
  }
  .landing__foot a { color: var(--fg-2); }
  .landing__foot a:hover { color: var(--accent); }

  @media (max-width: 720px) {
    .landing {
      padding-block: var(--space-7) var(--space-9);
      gap: var(--space-6);
    }
    .landing__name { font-size: var(--fs-2xl); }
    .landing__line { font-size: var(--fs-3xl); }
    .proof-strip { grid-template-columns: 1fr; }
    .proof-strip div + div {
      border-left: 0;
      border-top: 1px solid var(--rule);
    }
    .proof-strip div {
      padding-inline: 0;
    }
  }
</style>
