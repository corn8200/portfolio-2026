---
import BaseLayout from '@layouts/BaseLayout.astro';
import VoiceAgent from '@components/VoiceAgent.astro';
---
<BaseLayout
  title="John Cornelius"
  description="John Cornelius is an AI Engineer and Army Veteran scaling operational AI across manufacturing plants."
  showCanvas={true}
>
  <section class="landing shell-wide">
    <header class="landing__head" aria-labelledby="hero-name">
      <p class="editorial-mark t-mono">Harpers Ferry, WV &middot; US-eligible</p>
      <h1 id="hero-name" class="landing__name">John Cornelius</h1>
      <p class="landing__position">Industrial AI operator. Army aviation veteran.</p>
      <p class="landing__line">
        I build the operating layer around AI: real-time plant analytics, predictive control,
        agent workflows, and the human standards that make new systems stick.
      </p>
    </header>

    <dl class="proof-strip" aria-label="Career proof points">
      <div>
        <dt>9</dt>
        <dd>plants in the current AI / Six Sigma scope</dd>
      </div>
      <div>
        <dt>20</dt>
        <dd>years Army operations and aviation</dd>
      </div>
      <div>
        <dt>2</dt>
        <dd>promotions in roughly three years at Tamko</dd>
      </div>
    </dl>

    <section class="ask-panel" aria-labelledby="ask-title">
      <div class="ask-panel__head">
        <p class="h-eyebrow">Ask the CV</p>
        <h2 id="ask-title" class="h-1">Talk to John without scheduling first.</h2>
        <p class="t-body">
          Voice or text. Answers are grounded in the CV and cite the section they came from.
        </p>
      </div>
      <VoiceAgent />
    </section>

    <nav class="landing-links" aria-label="Primary paths">
      <a class="landing-link" href="/cv">
        <span class="t-mono">01</span>
        <strong>Read the CV</strong>
        <span class="t-meta">printable · markdown download</span>
      </a>
      <a class="landing-link" href="/work">
        <span class="t-mono">02</span>
        <strong>See the work</strong>
        <span class="t-meta">manufacturing · aviation · operator AI</span>
      </a>
      <a class="landing-link" href="/contact">
        <span class="t-mono">03</span>
        <strong>Start a conversation</strong>
        <span class="t-meta">email · GitHub · location</span>
      </a>
    </nav>

    <footer class="landing__foot t-meta">
      <span>corn82@icloud.com</span>
      <span aria-hidden="true">&middot;</span>
      <a href="https://github.com/corn8200" rel="noopener">github.com/corn8200</a>
    </footer>
  </section>
</BaseLayout>

<style>
  .landing {
    padding-block: clamp(var(--space-7), 10vh, var(--space-10)) var(--space-8);
    display: grid;
    gap: var(--space-7);
  }

  .landing__head { display: grid; gap: var(--space-3); max-width: 70rem; }
  .landing__name {
    font: 460 clamp(2.35rem, 5vw, 4rem)/1 var(--font-display);
    letter-spacing: var(--tracking-3xl);
    color: var(--fg);
    margin: 0;
  }
  .landing__position {
    font: 560 clamp(1.7rem, 4vw, 3.25rem)/1.08 var(--font-display);
    letter-spacing: var(--tracking-2xl);
    color: var(--fg);
    max-width: 15ch;
    margin: 0;
  }
  .landing__line {
    font-size: var(--fs-md);
    line-height: 1.5;
    color: var(--fg);
    max-width: 58ch;
    margin: 0;
  }

  .proof-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .proof-strip div {
    display: grid;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-5);
    border-right: 1px solid var(--rule);
  }
  .proof-strip div:last-child { border-right: 0; }
  .proof-strip dt {
    font: 560 var(--fs-3xl)/1 var(--font-display);
    color: var(--fg);
  }
  .proof-strip dd {
    color: var(--fg-2);
    font-size: var(--fs-sm);
    line-height: var(--lh-sm);
    margin: 0;
  }

  .ask-panel {
    display: grid;
    grid-template-columns: minmax(16rem, 0.65fr) minmax(0, 1fr);
    gap: var(--space-6);
    align-items: start;
  }
  .ask-panel__head {
    display: grid;
    gap: var(--space-3);
    padding-top: var(--space-2);
  }

  .landing-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }
  .landing-link {
    display: grid;
    gap: var(--space-2);
    padding-block: var(--space-4);
    border-top: 1px solid var(--rule);
    color: var(--fg);
    transition: background var(--dur-fast) var(--ease-standard);
  }
  .landing-link::after {
    content: '\2192';
    justify-self: start;
    color: var(--fg-3);
    transition: transform var(--dur-base) var(--ease-emphasized), color var(--dur-base) var(--ease-standard);
  }
  .landing-link:hover, .landing-link:focus-visible {
    background: color-mix(in oklch, var(--accent) 5%, transparent);
  }
  .landing-link:hover::after, .landing-link:focus-visible::after {
    transform: translateX(6px);
    color: var(--accent);
  }
  .landing-link .t-mono { color: var(--fg-3); font-size: var(--fs-xs); }
  .landing-link strong { font: 540 var(--fs-lg)/var(--lh-lg) var(--font-display); }

  .landing__foot {
    display: flex;
    gap: var(--space-3);
    color: var(--fg-3);
    flex-wrap: wrap;
    align-items: center;
  }
  .landing__foot a { color: var(--fg-2); }
  .landing__foot a:hover { color: var(--accent); }

  @media (max-width: 900px) {
    .ask-panel { grid-template-columns: 1fr; }
    .landing-links { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .proof-strip { grid-template-columns: 1fr; }
    .proof-strip div { border-right: 0; border-bottom: 1px solid var(--rule); padding-inline: 0; }
    .proof-strip div:last-child { border-bottom: 0; }
  }
</style>
