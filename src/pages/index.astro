---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout
  title="John Cornelius"
  description="AI & Six Sigma Lead at Tamko Building Products. Embry-Riddle MS Unmanned Systems. Veteran, 160th SOAR."
>
  <section class="landing shell">
    <header class="landing__head">
      <p class="editorial-mark t-mono">Harpers Ferry, WV &middot; US-eligible</p>
      <h1 class="landing__name">John Cornelius</h1>
      <p class="landing__line">
        AI &amp; Six Sigma Lead at Tamko Building Products. Twenty years of U.S. Army operations and aviation behind that.
      </p>
    </header>

    <nav class="doors" aria-label="Choose how to engage">
      <a class="door" href="/talk">
        <span class="door__idx t-mono">01</span>
        <span class="door__title">Talk to me</span>
        <span class="door__hint t-meta">live voice, my own &middot; cited from the CV</span>
      </a>
      <a class="door" href="/cv">
        <span class="door__idx t-mono">02</span>
        <span class="door__title">Read the CV</span>
        <span class="door__hint t-meta">save as pdf &middot; download .md</span>
      </a>
      <a class="door" href="/work">
        <span class="door__idx t-mono">03</span>
        <span class="door__title">See the career</span>
        <span class="door__hint t-meta">army aviation &middot; Tamko &middot; Embry-Riddle</span>
      </a>
    </nav>

    <footer class="landing__foot t-meta">
      <span>corn82@icloud.com</span>
      <span aria-hidden="true">&middot;</span>
      <a href="https://github.com/corn8200" rel="noopener">github.com/corn8200</a>
    </footer>
  </section>
</BaseLayout>

<style>
  .landing {
    min-height: 78svh;
    padding-block: clamp(var(--space-7), 12vh, var(--space-10));
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: var(--space-8);
    max-width: 64rem;
  }

  .landing__head { display: grid; gap: var(--space-4); }
  .landing__name {
    font: 460 clamp(2.75rem, 7vw, 5rem)/1 var(--font-display);
    letter-spacing: -0.025em;
    color: var(--fg);
    margin: 0;
  }
  .landing__line {
    font-size: var(--fs-md);
    line-height: 1.5;
    color: var(--fg);
    max-width: 48ch;
    margin: 0;
  }

  .doors {
    display: grid;
    gap: var(--space-3);
    align-content: start;
  }
  .door {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-4);
    border-top: 1px solid var(--rule);
    color: var(--fg);
    transition: background var(--dur-fast) var(--ease-standard);
    position: relative;
  }
  .door:last-of-type { border-bottom: 1px solid var(--rule); }
  .door::after {
    content: '\2192';
    grid-column: -1;
    color: var(--fg-3);
    font-size: var(--fs-md);
    transition: transform var(--dur-base) var(--ease-emphasized), color var(--dur-base) var(--ease-standard);
  }
  .door:hover, .door:focus-visible {
    background: color-mix(in oklch, var(--accent) 5%, transparent);
  }
  .door:hover::after, .door:focus-visible::after {
    transform: translateX(6px);
    color: var(--accent);
  }
  .door__idx { color: var(--fg-3); font-size: var(--fs-xs); }
  .door__title {
    font: 480 clamp(1.5rem, 3vw, 2.25rem)/1.05 var(--font-display);
    letter-spacing: -0.018em;
    color: var(--fg);
  }
  .door__hint { grid-column: 2 / 3; color: var(--fg-3); margin-top: var(--space-2); }

  .landing__foot {
    display: flex;
    gap: var(--space-3);
    color: var(--fg-3);
    flex-wrap: wrap;
    align-items: center;
  }
  .landing__foot a { color: var(--fg-2); }
  .landing__foot a:hover { color: var(--accent); }

  @media (max-width: 600px) {
    .door { grid-template-columns: 2rem 1fr auto; padding: var(--space-4) var(--space-2); }
    .door__hint { grid-column: 2 / 3; }
  }
</style>
