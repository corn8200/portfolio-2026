---
import BaseLayout from '@layouts/BaseLayout.astro';
import VoiceAgent from '@components/VoiceAgent.astro';
---
<BaseLayout
  title="Talk — John Cornelius"
  description="Real-time voice or text. Ask anything. Every answer cites which role or project it pulled from."
>
  <section class="shell talk">
    <header class="page-head">
      <p class="h-eyebrow">/ Conversation</p>
      <h1 class="h-display">Talk to me.</h1>
      <p class="t-lead">
        Voice or text. The voice you hear is mine — cloned via ElevenLabs from
        two voice memos. Ask about my Army career, my Tamko work, my degrees,
        or my approach to manufacturing AI. The model is grounded in this CV
        and cites the section it pulled from.
      </p>
    </header>

    <VoiceAgent />

    <p class="t-meta foot">
      Voice runs on my own ElevenLabs Instant Voice Clone. Want to know what I sound like before
      hopping on a call? Hit the voice button.
    </p>
  </section>
</BaseLayout>

<style>
  .talk { padding-block: var(--space-9) var(--space-10); display: grid; gap: var(--space-7); }
  .page-head { display: grid; gap: var(--space-3); max-width: 56rem; }
  .foot { color: var(--fg-3); max-width: 56rem; margin-inline: auto; }
  .foot code { font-family: var(--font-mono); background: var(--bg-2); padding: 1px 6px; border-radius: var(--r-1); color: var(--fg-2); }
</style>
