---
import BaseLayout from '@layouts/BaseLayout.astro';
import VoiceAgent from '@components/VoiceAgent.astro';
---
<BaseLayout
  title="Talk — John Cornelius"
  description="Ask John Cornelius by voice or text. Answers are grounded in the CV and cite the source section."
  showFooter={false}
>
  <section class="shell talk">
    <header class="page-head">
      <p class="h-eyebrow">/ Conversation</p>
      <h1 class="h-display">Ask John.</h1>
      <p class="t-lead">
        Voice or text, no intake wizard. Ask about Tamko, Army aviation,
        manufacturing AI, Overseer, or how the background maps to a role.
        Answers are grounded in this CV and cite the section they came from.
      </p>
    </header>

    <VoiceAgent />

    <p class="t-meta foot">
      Voice runs through ElevenLabs. Mute keeps the conversation text-only.
    </p>
  </section>
</BaseLayout>

<style>
  .talk { padding-block: var(--space-9) var(--space-10); display: grid; gap: var(--space-7); }
  .page-head { display: grid; gap: var(--space-3); max-width: 56rem; }
  .foot { color: var(--fg-3); max-width: 56rem; margin-inline: auto; }
  .foot code { font-family: var(--font-mono); background: var(--bg-2); padding: 1px 6px; border-radius: var(--r-1); color: var(--fg-2); }
</style>
