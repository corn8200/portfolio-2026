{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@lib/*": ["src/lib/*"],
      "@styles/*": ["src/styles/*"],
      "@content/*": ["content/*"]
    },
    "types": ["@cloudflare/workers-types", "astro/client"],
    "jsx": "preserve"
  },
  "include": ["src/**/*", "content/**/*", "*.d.ts", "astro.config.mjs"]
}
